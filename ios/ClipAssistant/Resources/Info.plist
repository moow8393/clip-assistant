<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Clipboard access description required for iOS 14+.
         Displayed in the system privacy prompt and Settings > Privacy > Pasteboard. -->
    <key>NSPasteboardUsageDescription</key>
    <string>ClipAssistant 在您切回 App 時自動讀取剪貼簿，偵測敏感關鍵字並提供遮罩選項。</string>

    <!-- SwiftUI App lifecycle: no explicit SceneDelegate needed;
         Xcode generates scene configuration automatically from @main App struct. -->
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>

    <!-- App Store compliance: declare no proprietary encryption is used. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

    <!-- Minimum OS version set via build settings; this key is informational only here. -->
    <key>MinimumOSVersion</key>
    <string>16.0</string>
</dict>
</plist>
