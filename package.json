{
  "name": "clip-assistant",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "setup:win": "powershell -ExecutionPolicy Bypass -File ./windows/create-shortcut.ps1",
    "test:win":"powershell -ExecutionPolicy Bypass -Command \"Invoke-Pester ./tests/windows/monitor.Tests.ps1 -Output Detailed\"",
    "dev:win": "powershell -ExecutionPolicy Bypass -File ./windows/monitor.ps1",
    "lint:win":   "powershell -Command \"Invoke-ScriptAnalyzer -Path ./windows/monitor.ps1\"",
    "format:win": "powershell -Command \"$f='./windows/monitor.ps1'; Set-Content $f (Invoke-Formatter -ScriptDefinition (Get-Content $f -Raw)) -Encoding UTF8\"",
    "info:ios": "echo 'Please open ./ios/ClipAssistant.xcodeproj in Xcode (Mac Required)'"
  },
